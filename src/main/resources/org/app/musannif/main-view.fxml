<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="800" maxWidth="1400" minHeight="800" minWidth="1400" prefHeight="800" prefWidth="1400" styleClass="root-pane" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.app.musannif.controller.MainController">

    <!-- ToggleGroup defined here so it is accessible across the whole scene -->
    <fx:define>
        <ToggleGroup fx:id="organizeGroup" />
    </fx:define>

    <!-- ═══════════════════════════════════════════════════════════
         CUSTOM TITLE BAR
    ════════════════════════════════════════════════════════════ -->
    <top>
        <HBox fx:id="titleBar" alignment="CENTER_LEFT" prefHeight="40" spacing="12" styleClass="title-bar">
            <padding><Insets left="12" right="12" /></padding>

            <ImageView fitHeight="24" fitWidth="24" pickOnBounds="true" preserveRatio="true">
                <image>
                    <Image url="@icons/app-icon-32.png" />
                </image>
            </ImageView>

            <Label styleClass="title-label" text="Musannif" />

            <Region HBox.hgrow="ALWAYS" />

            <Button fx:id="btnMinimize" mnemonicParsing="false" onAction="#handleMinimize" styleClass="window-control-btn" text="−" />
            <Button fx:id="btnMaximize" mnemonicParsing="false" onAction="#handleMaximize" styleClass="window-control-btn" text="□" />
            <Button fx:id="btnClose" mnemonicParsing="false" onAction="#handleClose" styleClass="window-control-btn,close-btn" text="✕" />
        </HBox>
    </top>

    <!-- ═══════════════════════════════════════════════════════════
         LEFT SIDEBAR  (220 px)
    ════════════════════════════════════════════════════════════ -->
    <left>
        <VBox maxWidth="220" minWidth="220" prefWidth="220" styleClass="sidebar">

            <!-- Logo row -->
            <HBox alignment="CENTER_LEFT" prefHeight="60" spacing="10" styleClass="logo-area">
                <padding><Insets bottom="14" left="20" right="20" top="16" /></padding>
                <ImageView fx:id="sidebarLogo" fitHeight="40" fitWidth="40" pickOnBounds="true" preserveRatio="true" styleClass="logo-icon" />
                <VBox spacing="2">
                    <Label styleClass="app-name" text="Musannif" />
                    <Label styleClass="app-tagline" text="مُصَنِّف · File organizer" />
                </VBox>
            </HBox>

            <Separator styleClass="sidebar-divider" />

            <!-- Section label -->
            <Label styleClass="nav-section-label" text="NAVIGATION">
                <VBox.margin><Insets bottom="8" left="20" right="20" top="14" /></VBox.margin>
            </Label>

            <!-- Organize (active) -->
            <HBox fx:id="navOrganize" onMouseClicked="#handleNavOrganize" alignment="CENTER_LEFT" prefHeight="44" spacing="10" styleClass="nav-item,nav-item-active">
                <padding><Insets left="17" right="20" /></padding>
                <Label fx:id="navOrganizeIcon" styleClass="nav-icon-active" text="⧉" />
                <Label fx:id="navOrganizeLabel" styleClass="nav-label-active" text="Organize" />
            </HBox>

            <!-- History -->
            <HBox fx:id="navHistory" onMouseClicked="#handleNavHistory" alignment="CENTER_LEFT" prefHeight="44" spacing="10" styleClass="nav-item">
                <padding><Insets left="20" right="20" /></padding>
                <Label fx:id="navHistoryIcon" styleClass="nav-icon" text="⏱" />
                <Label fx:id="navHistoryLabel" styleClass="nav-label" text="History" />
            </HBox>

            <!-- Push rest to bottom -->
            <Region VBox.vgrow="ALWAYS" />
         <Button fx:id="btnGenerateTestFiles" alignment="TOP_CENTER" contentDisplay="RIGHT" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" nodeOrientation="RIGHT_TO_LEFT" onAction="#handleGenerateTestFiles" prefHeight="19.0" prefWidth="138.0" styleClass="btn-accent" text="Generate Test Files" textAlignment="CENTER" translateX="40.0" translateY="-40.0" />
         <Button fx:id="btnAbout" alignment="TOP_CENTER" contentDisplay="RIGHT" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" nodeOrientation="RIGHT_TO_LEFT" onAction="#handleInfo" prefHeight="19.0" prefWidth="138.0" styleClass="btn-accent" text="About Musannif" textAlignment="CENTER" translateX="40.0" translateY="-20.0" />
         <Region prefWidth="219.0" />

        </VBox>
    </left>

    <!-- ═══════════════════════════════════════════════════════════
         MAIN CONTENT AREA
    ════════════════════════════════════════════════════════════ -->
    <center>
        <VBox styleClass="main-content">
            <VBox fx:id="organizePage" VBox.vgrow="ALWAYS">

                <!-- ── Controls card ─────────────────────────────── -->
            <VBox spacing="10" styleClass="controls-card">
                <padding><Insets bottom="12" left="14" right="14" top="12" /></padding>
                <VBox.margin><Insets bottom="0" left="14" right="14" top="14" /></VBox.margin>

                <!-- Row 1 — Folder -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label minWidth="60" styleClass="field-label" text="Folder" />
                    <TextField fx:id="txtFolderPath" editable="false" prefHeight="30" promptText="/Users/Downloads" styleClass="path-field" HBox.hgrow="ALWAYS" />
                    <Button fx:id="btnBrowse" onAction="#handleBrowse" prefHeight="30" prefWidth="72" styleClass="btn-filled" text="Browse" />
                </HBox>

                <!-- Row 2 — Organize by + actions -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label minWidth="60" styleClass="field-label" text="Organize" />

                    <!-- Pill-shaped radio chips -->
                    <HBox alignment="CENTER_LEFT" spacing="5" styleClass="chip-group">
                        <RadioButton fx:id="rbType" prefHeight="26.0" prefWidth="84.0" selected="true" styleClass="chip" text="File Type">
                     <toggleGroup>
                        <ToggleGroup fx:id="organizeGroup" />
                     </toggleGroup></RadioButton>
                        <RadioButton fx:id="rbDate" prefHeight="26.0" prefWidth="111.0" styleClass="chip" text="Date Modified" toggleGroup="$organizeGroup" />
                        <RadioButton fx:id="rbExt" prefHeight="26.0" prefWidth="85.0" styleClass="chip" text="Extension" toggleGroup="$organizeGroup" />
                  <Region prefHeight="30.0" prefWidth="6.0" />
                  <RadioButton fx:id="rbIcon" mnemonicParsing="false" prefHeight="17.0" prefWidth="67.0" styleClass="btn-icon" stylesheets="@styles.css" text="  Icons" />
                    </HBox>

                    <Region HBox.hgrow="ALWAYS" />

                    <Button fx:id="btnScan" disable="true" onAction="#handleScan" prefHeight="30" styleClass="btn-filled" text="Scan &amp; Preview" />

                    <Button fx:id="btnApply" disable="true" onAction="#handleApply" prefHeight="30" styleClass="btn-success" text="Apply Changes" />
                </HBox>
            </VBox>

            <!-- ── Done overlay (shown after organize) ──────── -->
            <VBox fx:id="doneOverlay" alignment="CENTER" managed="false" spacing="8" visible="false" VBox.vgrow="ALWAYS">
                <Label fx:id="lblDoneIcon" alignment="CENTER" style="-fx-font-size:72px;" text="✓" />
                <Label fx:id="lblDoneText" alignment="CENTER" style="-fx-font-size:36px;-fx-font-weight:bold;-fx-text-fill:#4ADE80;" text="Done!" />
                <Label fx:id="lblDoneSummary" alignment="CENTER" style="-fx-text-fill:#7B82A0;-fx-font-size:14px;" />
            </VBox>

            <!-- ── File table + Preview panel ───────────────── -->
            <HBox fx:id="tablePreviewContainer" VBox.vgrow="ALWAYS">
                <VBox.margin><Insets bottom="0" left="14" right="14" top="10" /></VBox.margin>

                <!-- File table -->
                <TableView fx:id="fileTable" styleClass="file-table" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                    <placeholder>
                        <VBox alignment="CENTER" spacing="8">
                            <Label style="-fx-font-size: 34;" text="📁" />
                            <Label fx:id="lblEmptyState" styleClass="empty-state-label" text="Select a folder to get started" />
                        </VBox>
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colName" minWidth="140" prefWidth="180" text="FILE NAME" />
                        <TableColumn fx:id="colExt" minWidth="80" prefWidth="180" text="EXT" />
                        <TableColumn fx:id="colSize" minWidth="80" prefWidth="180" text="SIZE" />
                        <TableColumn fx:id="colModified" minWidth="100" prefWidth="180" text="DATE" />
                    </columns>
                </TableView>

                <!-- Resize separator for preview panel -->
                <Separator fx:id="previewSeparator" managed="false" orientation="VERTICAL" styleClass="resize-separator" visible="false" HBox.hgrow="never" />

                <!-- Preview panel — shown after scan -->
                <VBox fx:id="previewPanel" managed="false" maxWidth="520" minWidth="200" prefWidth="380" styleClass="preview-panel" visible="false" HBox.hgrow="never" VBox.vgrow="ALWAYS">

                    <!-- Panel header -->
                    <HBox alignment="CENTER_LEFT" prefHeight="36" spacing="8" styleClass="preview-header">
                        <padding><Insets left="12" right="10" /></padding>
                        <VBox spacing="1" HBox.hgrow="ALWAYS">
                            <Label styleClass="preview-title" text="Proposed Structure" />
                            <Label fx:id="lblPreviewMethod" styleClass="preview-subtitle" text="by File Type" />
                        </VBox>
                    </HBox>

                    <!-- Destination path strip -->
                    <VBox styleClass="preview-path-bar" prefHeight="44">
                        <padding><Insets left="12" right="12" top="6" bottom="6" /></padding>
                        <Label text="DESTINATION" styleClass="dest-section-label" />
                        <Label fx:id="lblDestPath" styleClass="dest-path-label" text="/Downloads/{Documents, Images…}" />
                    </VBox>

                    <!-- Tree view -->
                    <TreeView fx:id="treePreview" showRoot="false" styleClass="preview-tree" VBox.vgrow="ALWAYS" />

                    <!-- Summary footer -->
                    <HBox alignment="CENTER_LEFT" prefHeight="30" styleClass="preview-footer">
                        <padding><Insets left="12" right="12" /></padding>
                        <Label fx:id="lblPreviewSummary" styleClass="preview-footer-label" text="15 files · 0 folders" HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblTotalSize" styleClass="preview-footer-label" text="1.8 GB total" />
                    </HBox>

                    <!-- Category legend -->
                    <FlowPane fx:id="legendBar" styleClass="legend-bar" hgap="10" vgap="4" VBox.vgrow="NEVER" />

                </VBox>
            </HBox>

            </VBox>

            <!-- ── History Page ──────────────────────────────────── -->
            <VBox fx:id="historyPage" managed="false" visible="false" VBox.vgrow="ALWAYS">

                <VBox spacing="10" styleClass="controls-card">
                    <padding><Insets bottom="12" left="14" right="14" top="12" /></padding>
                    <VBox.margin><Insets bottom="0" left="14" right="14" top="14" /></VBox.margin>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label minWidth="60" styleClass="field-label" text="History" />
                        <Label style="-fx-text-fill:#7B82A0;-fx-font-size:13px;" text="Past organize operations" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnRestoreOperation" onAction="#handleRestoreOperation" prefHeight="30" styleClass="btn-success" text="↩ Undo Operation" />
                    </HBox>
                </VBox>

                <TableView fx:id="historyTable" styleClass="file-table" VBox.vgrow="ALWAYS">
                    <VBox.margin><Insets bottom="0" left="14" right="14" top="10" /></VBox.margin>
                    <placeholder>
                        <Label styleClass="empty-state-label" text="No operations yet. Run an organize operation first." />
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colHistTime" minWidth="140" prefWidth="180" text="DATE / TIME" />
                        <TableColumn fx:id="colHistFolder" minWidth="100" prefWidth="160" text="FOLDER" />
                        <TableColumn fx:id="colHistMode" minWidth="80" prefWidth="120" text="MODE" />
                        <TableColumn fx:id="colHistMoved" minWidth="60" prefWidth="100" text="MOVED" />
                        <TableColumn fx:id="colHistSkipped" minWidth="60" prefWidth="100" text="SKIPPED" />
                    </columns>
                </TableView>

            </VBox>

            <!-- ── Status bar ─────────────────────────────────── -->
            <HBox fx:id="statusBar" alignment="CENTER_LEFT" prefHeight="33" spacing="10" styleClass="status-bar">
                <padding><Insets left="14" right="14" /></padding>

                <Label fx:id="lblStatus" styleClass="status-label" text="Select a folder to get started" HBox.hgrow="ALWAYS" />

                <Button fx:id="btnOpenFolder" onAction="#handleOpenFolder" styleClass="btn-toggle-preview" text="Open Folder" visible="false" />

                <Button fx:id="btnTogglePreview" onAction="#handlePreview" styleClass="btn-toggle-preview" text="Show preview" visible="false" />

                <ProgressBar fx:id="scanProgress" managed="false" prefHeight="3" prefWidth="110" progress="0" styleClass="scan-progress" visible="false" />

            </HBox>

        </VBox>
    </center>

</BorderPane>
